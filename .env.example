# Required: Claude API for script generation and validation
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Groq API for audio transcription (Whisper)
GROQ_API_KEY=gsk_...

# Optional: Groq free tier key (used by default for files <25MB)
# Create a free account at console.groq.com (no credit card needed)
GROQ_API_KEY_FREE=gsk_...
